# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vpn_control
DB_USER=vpn_user
DB_PASSWORD=change_me
SSL_PATH=
DB_POOL_SIZE=20
DB_POOL_OVERFLOW_SIZE=10
DB_POOL_TIMEOUT_SEC=30

# Edge / public endpoint
VPN_PUBLIC_DOMAIN=

# Redis
REDIS_BROKER_URL=redis://localhost:6379/0
REDIS_ASSIGNMENTS_CACHE_TTL=10
REDIS_ASSIGNMENT_LOCK_TTL=30

# NATS
NATS_ENABLED=false
NATS_SERVER=nats://localhost:4222
NATS_NAME=vpn-control-api
NATS_USERS_TRAFFIC_SUBJECT=users.traffic
NATS_USERS_TRAFFIC_QUEUE=vpn-control-api-users-traffic
NATS_RECONNECT_TIME_WAIT=2
NATS_RECONNECT_ATTEMPTS=-1
NATS_JS_COMMAND_STREAM=agent_placement_commands
NATS_JS_RESULT_STREAM=agent_placement_results
NATS_JS_CONTROL_STREAM=agent_control_events
NATS_JS_COMMAND_SUBJECT_PREFIX=agent.placements
NATS_JS_RESULT_SUBJECT_PREFIX=agent.placement_results
NATS_JS_SNAPSHOT_SUBJECT_PREFIX=agent.snapshots
NATS_JS_HEARTBEAT_SUBJECT_PREFIX=agent.heartbeats
NATS_JS_SYNC_REPORT_SUBJECT_PREFIX=agent.sync_reports
NATS_JS_CONSUMER_PREFIX=vpn-control-api
NATS_JS_ACK_WAIT_S=30
NATS_JS_MAX_DELIVER=30
NATS_JS_FETCH_TIMEOUT_S=1

# Auth
ADMIN_API_KEY_HASH=
CONNECT_API_KEY_HASH=
BOOTSTRAP_TOKEN_HASH=
PROBE_TOKEN_HASH=

# Docs auth
DOCS_USERNAME=admin
DOCS_PASSWORD_HASH=

# Profiles
PROFILES_ALLOW_EMPTY_REGISTRY_ON_STARTUP=true

# Subscriptions
SUBSCRIPTIONS_REQUIRE_HWID_DEFAULT=false
SUBSCRIPTIONS_MAX_DEVICES_DEFAULT=5
SUBSCRIPTIONS_HWID_HEADER=x-hwid
SUBSCRIPTIONS_SMART_ROUTE_MAX_COUNT=6
SUBSCRIPTIONS_RESPONSE_CACHE_TTL_SEC=15
SUBSCRIPTIONS_RESPONSE_MAX_PAYLOAD_BYTES=32768
SUBSCRIPTIONS_PUBLIC_BASE_URL=
SUBSCRIPTIONS_HAPP_PROFILE_TITLE=VPN
SUBSCRIPTIONS_HAPP_PROFILE_UPDATE_INTERVAL_HOURS=24
SUBSCRIPTIONS_HAPP_SUPPORT_URL=
SUBSCRIPTIONS_HAPP_PROFILE_WEB_PAGE_URL=
SUBSCRIPTIONS_HAPP_PROVIDER_ID=
SUBSCRIPTIONS_HAPP_ROUTING=

# Node agent
NODE_SYNC_REPORT_DEBOUNCE_SEC=10
NODE_AUTH_TOKEN_ROTATION_GRACE_SEC=300
NODE_BOOTSTRAP_ALLOW_CREATE=true
NODE_HEARTBEAT_UNHEALTHY_DRAIN_THRESHOLD=2
NODE_HEARTBEAT_HEALTHY_UNDRAIN_THRESHOLD=3
NODE_STALE_AFTER_SEC=90
NODE_AUTO_HEAL_ENABLED=false
NODE_AUTO_HEAL_TICK_SEC=60
NODE_AUTO_HEAL_MAX_NODES=20
NODE_AUTO_UNDRAIN_ENABLED=false

# Alerts
ALERTS_TELEGRAM_ENABLED=false
ALERTS_TELEGRAM_BOT_TOKEN=
ALERTS_TELEGRAM_CHAT_ID=
ALERTS_TELEGRAM_TIMEOUT_SEC=5

# Probe
PROBE_TARGET_PORT=443
PROBE_RETENTION_DAYS=30
PROBE_CLEANUP_ENABLED=true
PROBE_CLEANUP_TICK_SEC=3600
PROBE_AUTO_ROUTE_HEALTH_ENABLED=true
PROBE_ROUTE_BLOCK_COOLDOWN_HOURS=6
PROBE_AUTO_DRAIN_MIGRATE_ENABLED=false
PROBE_AUTO_DRAIN_TICK_SEC=120
PROBE_AUTO_DRAIN_SOURCE=
PROBE_AUTO_DRAIN_REQUIRE_RECENT_FAILURE=true
PROBE_AUTO_DRAIN_MAX_PROBE_AGE_SEC=600
PROBE_AUTO_DRAIN_MIN_CONSECUTIVE_FAILURES=2
PROBE_AUTO_DRAIN_INCLUDE_ALREADY_DRAINING=false
PROBE_AUTO_DRAIN_MAX_NODES=20
PROBE_AUTO_DRAIN_TARGET_BACKEND_ID=
PROBE_AUTO_DRAIN_LAST_MIGRATION_REASON=probe_auto_failure

# Routes/connect
ROUTES_WARMUP_TICK_SEC=300
ROUTES_CONNECT_REFRESH_INTERVAL_SEC=60
ROUTES_CONNECT_MAX_CACHE_AGE_SEC=300
ROUTES_CONNECT_BACKOFF_STEPS_SEC=2,5,10,30,60
ROUTES_CONNECT_TELEMETRY_DEBOUNCE_SEC=10
ROUTES_CONNECT_TELEMETRY_FAILURE_WINDOW_SEC=300
ROUTES_CONNECT_TELEMETRY_DEGRADED_THRESHOLD=2
ROUTES_CONNECT_TELEMETRY_BLOCK_THRESHOLD=3
ROUTES_CONNECT_TELEMETRY_BLOCK_COOLDOWN_HOURS=6

# Traffic usage history
TRAFFIC_CLEANUP_ENABLED=false
TRAFFIC_CLEANUP_TICK_SEC=3600
TRAFFIC_HISTORY_RETENTION_DAYS=14

# Admin auth (session/cookie login)
ADMIN_AUTH_ENABLED=false
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SEC=86400
ADMIN_SESSION_COOKIE_SECURE=true
ADMIN_TELEGRAM_LOGIN_ENABLED=false
ADMIN_TELEGRAM_CLIENT_ID=
ADMIN_TELEGRAM_CLIENT_SECRET=
ADMIN_TELEGRAM_REDIRECT_URI=
ADMIN_TELEGRAM_AUTHORIZE_URL=https://oauth.telegram.org/auth
ADMIN_TELEGRAM_TOKEN_URL=https://oauth.telegram.org/token
ADMIN_TELEGRAM_JWKS_URL=https://oauth.telegram.org/.well-known/jwks.json
ADMIN_TELEGRAM_ISSUER=https://oauth.telegram.org
ADMIN_TELEGRAM_ALLOWED_IDS=
